---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "Project Alpha",
    desc: "A full-stack web app that does something impressive. Built to solve a real problem that many people face every day.",
    tags: ["React", "Node.js", "PostgreSQL"],
    year: "2024",
    link: "#",
  },
  {
    title: "Project Beta",
    desc: "An open-source tool that helps developers move faster without breaking things. Ships as a single binary.",
    tags: ["Rust", "CLI", "Open Source"],
    year: "2024",
    link: "#",
  },
  {
    title: "Project Gamma",
    desc: "A design system and component library used across multiple production apps. Fully typed and documented.",
    tags: ["TypeScript", "Astro", "CSS"],
    year: "2023",
    link: "#",
  },
  {
    title: "Project Delta",
    desc: "A real-time collaboration tool with live cursors and conflict-free editing built on CRDTs.",
    tags: ["WebSockets", "React", "Redis"],
    year: "2023",
    link: "#",
  },
  {
    title: "Project Epsilon",
    desc: "A static-site generator plugin that auto-generates OG images at build time — zero runtime cost.",
    tags: ["Node.js", "Canvas", "Plugin"],
    year: "2022",
    link: "#",
  },
  {
    title: "Project Zeta",
    desc: "A browser extension that strips distractions and reformats long articles for focus reading.",
    tags: ["JavaScript", "Browser Extension", "CSS"],
    year: "2022",
    link: "#",
  },
];
---

<BaseLayout title="Projects" description="A collection of projects I've built">
  <div class="container">
    <header class="page-header">
      <h1>Projects</h1>
      <p>Things I've built — side projects, open source, and client work.</p>
    </header>

    <div class="project-list">
      {projects.map(({ title, desc, tags, year, link }) => (
        <a href={link} class="project-row">
          <div class="project-meta">
            <span class="project-year">{year}</span>
            <h2>{title}</h2>
          </div>
          <p>{desc}</p>
          <div class="tag-row">
            {tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .container { padding-top: 3rem; padding-bottom: 4rem; }

  .page-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
  }
  .page-header h1 { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
  .page-header p { color: var(--muted); font-size: 1rem; }

  .project-list { display: flex; flex-direction: column; gap: 1px; }

  .project-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: start;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    transition: background 0.15s;
    border-radius: 4px;
  }
  .project-row:hover { background: var(--surface); padding-left: 1rem; padding-right: 1rem; }

  .project-meta { display: flex; flex-direction: column; gap: 0.25rem; }
  .project-year { color: var(--muted); font-size: 0.8rem; }
  .project-meta h2 { font-size: 1rem; font-weight: 600; }

  .project-row p { color: var(--muted); font-size: 0.875rem; line-height: 1.6; }

  .tag-row { display: flex; gap: 0.4rem; flex-wrap: wrap; justify-content: flex-end; }

  @media (max-width: 640px) {
    .project-row { grid-template-columns: 1fr; }
    .tag-row { justify-content: flex-start; }
  }
</style>
